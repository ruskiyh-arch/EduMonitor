<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section: choose subject -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выберите предмет"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp"/>

            <!-- Math card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_math"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="📐"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:layout_marginEnd="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Математика"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Russian card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_russian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="📖"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:layout_marginEnd="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Русский язык"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- English card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_english"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="🇬🇧"
                        android:textSize="26sp"
                        android:gravity="center"
                        android:layout_marginEnd="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Английский язык"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: choose grade -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выберите класс"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinner_grade"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:padding="8dp"
                android:layout_marginBottom="24dp"/>

            <!-- Start test button -->
            <Button
                android:id="@+id/btn_start_test"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Начать тест"
                android:textSize="16sp"
                android:padding="14dp"
                android:backgroundTint="#3F51B5"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp"/>

            <!-- Logout -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Выйти"
                android:textSize="14sp"
                android:padding="10dp"
                android:backgroundTint="#FFFFFF"
                android:textColor="#F44336"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
